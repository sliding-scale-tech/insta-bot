# ── Secrets ────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Instagram session (contains login cookies — never commit) ───────────────
chrome_profile/
data/

# ── Debug output (screenshots, HTML reports) ───────────────────────────────
debug_output/

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ────────────────────────────────────────────────────
venv/
.venv/
env/
.env/

# ── Node / pnpm ─────────────────────────────────────────────────────────────
node_modules/
dashboard/node_modules/
dashboard/dist/
dashboard/.pnpm-store/
pnpm-debug.log*

# ── Convex ──────────────────────────────────────────────────────────────────
.convex/
convex/_generated/
# dashboard/convex/_generated/ is intentionally tracked (not ignored) — it's a
# small runtime-compatible stub (see dashboard/convex/_generated/api.ts) that
# Vercel's build needs since it can't run `npx convex dev` during CI.

# ── Docker ──────────────────────────────────────────────────────────────────
.dockerignore

# ── Logs ───────────────────────────────────────────────────────────────────
*.log
logs/

# ── OS ─────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Claude worktrees (internal tooling) ────────────────────────────────────
.claude/worktrees/


.node_modules/


