username=your_instagram_username
email=your_email@gmail.com
password=your_password

# Default login method for authenticate.py: facebook, email, username, manual
LOGIN_METHOD=facebook

# Optional settings
TOTP_SEED=
VERIFICATION_CODE=
PHONE_NUMBER=
PROXY=

# Session files (stored in data/ folder by default)
SESSION_FILE=data/session.json
BROWSER_STATE_FILE=data/browser_state.json
BROWSER_COOKIES_FILE=data/browser_cookies.json

HASHTAG_TO_SEARCH=realestate
COMMENT_TEXT=Incredible work! Thanks for sharing this.
DM_MESSAGE=Hey there! I saw your post under the hashtag and wanted to connect.
MAX_COMMENTS=1
MAX_DMS=0

# Run browser bot instead of instagrapi API
USE_BROWSER=true

# Gemini agent (add key before running agent — not needed for tool tests)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
SESSION_MINUTES=20
MAX_COMMENTS_PER_SESSION=5
MAX_REPLIES_PER_SESSION=5
AGENT_PERSONA=You are a friendly developer who enjoys Python and coding content on Instagram.
AGENT_DRY_RUN=false
